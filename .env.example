# ============================================================================
# Sivas İtfaiye Dijital Yönetim Sistemi — Ortam Değişkenleri Şablonu
# ----------------------------------------------------------------------------
# Bu dosya bir ŞABLONDUR. Gerçek değerleri BURAYA YAZMAYIN.
# Kopyalayıp `.env` (veya `.env.local`) oluşturun ve gerçek değerleri orada
# doldurun. `.env*` dosyaları .gitignore ile sürüm kontrolünden hariç tutulur;
# yalnızca bu `.env.example` şablonu commit edilir.
# ============================================================================

# ─── Çalışma Ortamı ─────────────────────────────────────────────────────────
# production değerinde güvenlik kalkanları etkinleşir:
#  - JWT_SECRET zorunlu olur (tanımsızsa uygulama başlamaz)
#  - NVİ kimlik doğrulama servis kesintisinde başvuru REDDEDİLİR (fail-closed)
#  - Vatandaş başvuru OTP kodu yanıtta DÖNMEZ (yalnızca SMS ile gönderilir)
NODE_ENV=development

# ─── Veritabanı (ZORUNLU) ───────────────────────────────────────────────────
# PostgreSQL (PostGIS eklentili) bağlantı dizesi.
DATABASE_URL=postgresql://KULLANICI:PAROLA@HOST:5432/VERITABANI_ADI

# (Opsiyonel / eski) Bazı bakım scriptleri bu parçalı değerleri okuyabilir.
# Uygulama çalışma zamanı yalnızca DATABASE_URL kullanır.
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# ─── Kimlik Doğrulama / Güvenlik (ZORUNLU) ──────────────────────────────────
# JWT imzalama anahtarı. Üretimde EN AZ 16 karakter olmalı ve gizli tutulmalıdır.
# Güçlü bir değer üretmek için: `openssl rand -base64 48`
JWT_SECRET=degistirin-en-az-16-karakterlik-guclu-rastgele-anahtar

# ─── QR / Uygulama Adresi ───────────────────────────────────────────────────
# Üretilen QR kodlarının işaret edeceği temel URL (araç/bölme derin linkleri).
NEXT_PUBLIC_SITE_URL=https://itfaiye.sivas.bel.tr

# ─── Kurulum / Seed Koruması (ZORUNLU — /api/seed ve /api/setup için) ────────
# Tanımlı DEĞİLSE seed/setup uçları 404 döner (fail-closed). Uzun ve rastgele
# bir değer olmalıdır; istekte `x-setup-token` başlığıyla gönderilir.
SETUP_API_TOKEN=degistirin-uzun-rastgele-kurulum-tokeni

# ─── Sayım Uyarısı Test/Önizleme Ucu Koruması — Opsiyonel ────────────────────
# Sayım uyarıları HARİCİ CRON GEREKTİRMEZ; uygulama içi zamanlayıcı
# (src/instrumentation.ts) her ~10 dk çalışıp her şubenin posta+20dk anını
# kendisi yakalar. CRON_SECRET yalnızca /api/cron/sayim-uyari test/önizleme
# ucunu korur (?dryRun=1 ile kimlere gideceğini görmek için). Tanımlı değilse
# bu uç 503 döner; otomatik gönderim yine de çalışır.
CRON_SECRET=degistirin-uzun-rastgele-token

# ─── Sivas Belediyesi SMS API (SMS ve OTP için) ─────────────────────────────
SMS_API_KEY=
SMS_API_SECRET=

# ─── Web Push Bildirimleri (VAPID) — Opsiyonel ──────────────────────────────
# Tanımlı değilse push bildirimleri sessizce devre dışı kalır.
# Üretmek için: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Mobiliz Araç Takip — Opsiyonel ─────────────────────────────────────────
# Token yoksa/demo ise sistem simülasyon moduna düşer.
MOBILIZ_BASE_URL=https://ng.mobiliz.com.tr/su7/api/integrations
MOBILIZ_TOKEN=

# ─── N2Mobil / WeTrack Araç Takip — Opsiyonel ───────────────────────────────
# Tercihen kullanıcı adı + parola; yoksa statik token'a düşer.
N2_USERNAME=
N2_PASSWORD=
N2MOBIL_TOKEN=

# ─── Google Gemini AI (Olay raporu PDF içe aktarma) — Opsiyonel ─────────────
GEMINI_API_KEY=

# ─── Dosya Depolama: MinIO (assets.sivas.bel.tr) ─────────────────────────────
# Tüm yüklemeler MinIO'ya <bucket>/itfaiye/<klasör>/ altına gider.
# Erişim: https://<endpoint>/<bucket>/itfaiye/<klasör>/<dosya>
# ACCESS/SECRET zorunlu; diğerleri belirtilmezse aşağıdaki üretim varsayılanları kullanılır.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_ENDPOINT=assets.sivas.bel.tr
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_BUCKET=public
MINIO_PUBLIC_URL=https://assets.sivas.bel.tr

# ─── Test Kimlik Kalkanı — Opsiyonel (DİKKAT) ───────────────────────────────
# 'true' yapılırsa üretimde bile test/sahte TC'ler ve NVİ servis kesintisinde
# fail-open davranışı ETKİNLEŞİR. Üretimde KESİNLİKLE ayarlamayın; yalnızca
# kontrollü demo/test ortamları içindir.
ALLOW_TEST_IDENTITY=
